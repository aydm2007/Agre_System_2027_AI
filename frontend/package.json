{
  "name": "saradud-frontend",
  "version": "2.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --force",
    "build": "vite build",
    "preview": "vite preview --host",
    "test": "vitest",
    "test:ci": "node scripts/run-vitest-batches.mjs",
    "test:e2e": "playwright test",
    "test:e2e:headed": "set HEADED=true&& playwright test",
    "test:e2e:all": "playwright test tests/e2e/all_pages.spec.js",
    "test:e2e:finance": "playwright test tests/e2e/financial_workflow.spec.js tests/e2e/sales_financial_lifecycle.spec.js",
    "test:e2e:finance:smoke": "playwright test tests/e2e/financial_workflow.spec.js",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix",
    "prepare": "cd .. && husky install frontend/.husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "generate-api": "node scripts/generate-api.js",
    "clean": "node -e \"const fs=require('fs');['dist','.dist-local','.vite','.vite-local','test-results','playwright-report','.pw-results'].forEach(p=>fs.rmSync(p,{recursive:true,force:true}))\""
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.0.18",
    "@tanstack/react-query": "^5.90.20",
    "axios": "^1.7.7",
    "chart.js": "^4.5.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dexie": "^3.2.4",
    "framer-motion": "^12.29.2",
    "html5-qrcode": "^2.3.8",
    "htmx.org": "^2.0.7",
    "i18next": "^25.8.13",
    "idb-keyval": "^6.2.2",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.563.0",
    "moment": "^2.30.1",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.3.0",
    "react-csv": "^2.2.2",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^6.27.0",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@playwright/test": "^1.57.0",
    "@storybook/addon-a11y": "^10.1.11",
    "@storybook/addon-docs": "^10.1.11",
    "@storybook/addon-onboarding": "^10.1.11",
    "@storybook/addon-vitest": "^10.1.11",
    "@storybook/react-vite": "^10.1.11",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.17",
    "baseline-browser-mapping": "^2.9.11",
    "esbuild": "^0.25.10",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-storybook": "^10.1.11",
    "husky": "^8.0.3",
    "jsdom": "^27.0.1",
    "lint-staged": "^15.2.2",
    "openapi-typescript-codegen": "^0.30.0",
    "playwright": "^1.57.0",
    "postcss": "^8.4.35",
    "prettier": "^3.2.5",
    "storybook": "^10.1.11",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^3.2.4"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  }
}
